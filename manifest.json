{
  "manifest_version": 3,
  "name": "Yandex Maps Fuel Cost Calculator",
  "version": "1.0.0",
  "description": "Показывает стоимость бензина для маршрутов на Яндекс Карте",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://yandex.ru/maps/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://yandex.ru/maps/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

